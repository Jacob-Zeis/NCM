---
import { SITE } from "../site.config";

const {
  title = `${SITE.name} — Precious Metals Buying`,
  description = "Appointment-only precious metals buying and appraisals in North County San Diego.",
  canonical = "/",
} = Astro.props;

const url = new URL(canonical, Astro.site);
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<link rel="canonical" href={url.toString()} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={url.toString()} />

<meta name="twitter:card" content="summary_large_image" />

<link rel="icon" href="/images/ncglogo-transparent.png" />

<script type="application/ld+json">
{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.name,
  "telephone": SITE.phoneE164,
  "email": SITE.email,
  "areaServed": SITE.serviceArea,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "San Diego",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "url": `https://${SITE.domain}`,
  "openingHours": SITE.hours
})}
</script>
