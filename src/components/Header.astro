---
import { SITE, LINKS } from "../site.config";
const { pathname } = Astro.url;
---

<header class="header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={SITE.name}>
      <span class="brand-mark">AM</span>
      <span class="brand-name">{SITE.name}</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {LINKS.map((l) => (
        <a class={pathname === l.href ? "nav-link active" : "nav-link"} href={l.href}>
          {l.label}
        </a>
      ))}
    </nav>

    <div class="header-cta">
      <a class="btn btn-ghost" href={`tel:${SITE.phoneE164}`}>Call</a>
      <a class="btn btn-primary" href={`sms:${SITE.smsE164}`}>Text Photos</a>
    </div>
  </div>

  <div class="container" style="padding: 0 20px 12px">
    <div class="muted" style="font-size: .92rem">
      Licensed • ID required • Receipts provided • Discreet mobile appointments
    </div>
  </div>
</header>
