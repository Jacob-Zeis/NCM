---
import { LINKS, SITE } from "../site.config";
---

<header class="header">
  <aside class="side-rail" aria-label={SITE.name}>
    <a class="rail-mark" href="/" aria-label={SITE.name}>
      <img
        src="/images/ncglogo-transparent.png"
        alt="North County Gold logo"
        width="104"
        height="104"
        decoding="async"
      />
    </a>
    <p class="rail-copy">
      North County San Diego / XRF Testing / Gold Silver Platinum / {SITE.phoneDisplay}
    </p>
  </aside>

  <div class="topbar">
    <div class="topbar-row topbar-small">
      <nav class="utility-nav" aria-label="Secondary">
        <a href="/pricing">Pricing</a>
        <a href="/faq">FAQ</a>
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </nav>
      <div class="utility-nav utility-nav-right">
        <a href="/contact">Appointment Only</a>
        <a href={`tel:${SITE.phoneE164}`}>{SITE.phoneDisplay}</a>
      </div>
    </div>

    <div class="topbar-row">
      <a class="wordmark" href="/" aria-label={SITE.name}>
        <span>North County</span>
        <span>Gold</span>
      </a>
      <div class="top-actions">
        <a class="btn btn-ghost" href="/contact">Private Appointment</a>
        <a class="btn btn-primary" href={`sms:${SITE.smsE164}`}>Text Photos</a>
      </div>
    </div>

    <nav class="primary-nav nav-row" aria-label="Primary">
      {LINKS.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
  </div>
</header>
