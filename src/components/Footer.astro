---
import { SITE } from "../site.config";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div>
      <div class="footer-title">{SITE.name}</div>
      <div class="muted">Mobile • {SITE.city}</div>
      <div class="muted">{SITE.hours}</div>
    </div>

    <div class="footer-links">
      <a href={`tel:${SITE.phoneE164}`}>{SITE.phoneDisplay}</a>
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      <a href="/contact">Book an appointment</a>
    </div>

    <div class="muted footer-note">
      Transparent testing in front of you. Immediate payout. Not a pawn shop.
    </div>

    <div class="muted">© {year} {SITE.legalName}. All rights reserved.</div>
  </div>
</footer>