---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import CardGrid from "../components/CardGrid.astro";
import PageIntro from "../components/PageIntro.astro";
import { BUY_ITEMS, SITE } from "../site.config";
---

<BaseLayout title={`What We Buy — ${SITE.name}`} canonical="/what-we-buy">
  <div class="container">
    <section class="section">
      <PageIntro title="What we buy" lead="Gold, silver, platinum, coins, bullion, estate lots, and gem-set jewelry." />
      <CardGrid items={BUY_ITEMS} />
    </section>

    <CTA />
  </div>
</BaseLayout>
