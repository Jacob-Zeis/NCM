---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import CardGrid from "../components/CardGrid.astro";
import PageIntro from "../components/PageIntro.astro";
import { SITE } from "../site.config";

const values = [
  {
    title: "Local",
    text: "Built for North County sellers who want a straightforward appointment.",
  },
  {
    title: "Transparent",
    text: "Testing and weighing happen in front of you.",
  },
  {
    title: "Documented",
    text: "Larger collections and estate lots are handled with clear records.",
  },
];
---

<BaseLayout title={`About — ${SITE.name}`} canonical="/about">
  <div class="container">
    <section class="section">
      <PageIntro title={`About ${SITE.name}`} lead="Appointment-only precious metals buying in North County San Diego." />
      <CardGrid items={values} />
    </section>

    <CTA />
  </div>
</BaseLayout>
