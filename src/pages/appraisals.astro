---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
---
<BaseLayout title="Appraisals — Aurelius Metals" canonical="/appraisals">
  <div class="container">
    <h1>Appraisals</h1>
    <p class="muted">
      Appraiser-forward positioning for estates, insurance, divorce, and high-value jewelry collections.
      Appraisal first, optional purchase second — transparent and defensible.
    </p>

    <div class="hr"></div>

    <div class="grid">
      <div class="card">
        <h3>What we provide</h3>
        <ul class="muted">
          <li>Jewelry & gemstone valuation (estate, insurance, divorce)</li>
          <li>Written documentation for clients and professionals</li>
          <li>Optional liquidity: market-based purchase offers after appraisal delivery</li>
        </ul>
      </div>

      <div class="card">
        <h3>Conflict-of-interest handling</h3>
        <p class="muted">
          We separate appraisal from purchase. The appraisal is delivered first as an independent valuation.
          After delivery, the client can choose to sell — or not.
        </p>
      </div>
    </div>

    <CTA heading="Need an appraisal or professional referral?" sub="Reach out and we’ll confirm scope, turnaround, and documentation needs." />
  </div>
</BaseLayout>
