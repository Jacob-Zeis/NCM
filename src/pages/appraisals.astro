---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import CardGrid from "../components/CardGrid.astro";
import PageIntro from "../components/PageIntro.astro";
import { SITE } from "../site.config";

const appraisalItems = [
  {
    title: "Documentation",
    text: "Written support for estates, insurance, divorce, and high-value jewelry collections.",
  },
  {
    title: "Optional purchase",
    text: "Appraisal first, optional market-based purchase offer after delivery.",
  },
];
---

<BaseLayout title={`Appraisals — ${SITE.name}`} canonical="/appraisals">
  <div class="container">
    <section class="section">
      <PageIntro title="Appraisals" lead="Jewelry and collection valuation. Purchase offers kept separate from appraisal delivery." />
      <CardGrid items={appraisalItems} columns="grid-2" />
    </section>

    <CTA heading="Need an appraisal or professional referral?" sub="Reach out and we’ll confirm scope, turnaround, and documentation needs." />
  </div>
</BaseLayout>
