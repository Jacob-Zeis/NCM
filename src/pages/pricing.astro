---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import CardGrid from "../components/CardGrid.astro";
import PageIntro from "../components/PageIntro.astro";
import { PRICING_FACTORS, SITE } from "../site.config";
---

<BaseLayout title={`Pricing — ${SITE.name}`} canonical="/pricing">
  <div class="container">
    <section class="section">
      <PageIntro title="How pricing works" lead="Offers are based on metal content, weight, item type, and current market conditions." />
      <CardGrid items={PRICING_FACTORS} />
    </section>

    <CTA />
  </div>
</BaseLayout>
