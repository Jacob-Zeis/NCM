---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../site.config";
---

<BaseLayout
  title={`${SITE.name} — Sell Gold in North County San Diego`}
  description="Sell gold, silver, platinum, coins, bullion, and gem-set jewelry locally in North County San Diego with XRF testing, clear offers, and same-day payout."
  canonical="/"
>
  <div class="container">
    <section class="brutal-home section-first">
      <div class="brutal-grid">
        <header class="brutal-title">
          <p class="eyebrow">North County Gold</p>
          <h1>Gold buying, handled locally.</h1>
        </header>

        <div class="brutal-action">
          <p class="eyebrow">Start here</p>
          <h2>Text photos before you book.</h2>
          <div class="home-buttons">
            <a class="btn btn-primary" href={`sms:${SITE.smsE164}`}>Text Photos</a>
            <a class="btn btn-ghost" href="/contact">Private Appointment</a>
          </div>
        </div>

        <article class="brutal-copy">
          <h2>Appointment-only precious metals buyer.</h2>
          <p>North County San Diego. Gold, silver, platinum, coins, bullion, and estate lots.</p>
        </article>

        <article class="brutal-copy brutal-copy-alt">
          <h2>Final offers follow in-person review.</h2>
          <p>Purity, weight, item type, and market conditions affect the number.</p>
        </article>

        <section class="photo-board" aria-label="Photo examples">
          <div class="sample-photo sample-photo-soft">
            <span>Gold chain</span>
          </div>
          <div class="sample-photo sample-photo-bright">
            <span>Coin face</span>
          </div>
          <div class="photo-center">
            <p class="asset-line">Gold / Silver / Platinum / Coins / Bullion / Gem-set jewelry</p>
            <h2>Send clear item photos</h2>
            <p>Include markings, coin faces, bars, stones, and any known weight.</p>
            <a class="btn btn-primary" href={`sms:${SITE.smsE164}`}>Text Photos</a>
          </div>
          <div class="sample-photo sample-photo-dark">
            <span>Bullion bar</span>
          </div>
          <div class="sample-photo sample-photo-pale">
            <span>Gem-set ring</span>
          </div>
        </section>
      </div>
    </section>
  </div>
</BaseLayout>
