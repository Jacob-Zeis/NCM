---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import CoinSpin from "../components/CoinSpin.astro";
import { SITE } from "../site.config";
---
<BaseLayout
  title={`${SITE.name} — Mobile Precious Metals Buying in San Diego`}
  description="Transparent XRF testing in front of you, immediate payout, and discreet mobile appointments across San Diego."
  canonical="/"
>
  <div class="container">
    <section class="hero">
      <div>
        <h1>Mobile precious metals buying — tested in front of you.</h1>
        <p class="lead">
          We buy gold, silver, platinum, and bullion across {SITE.city}. Professional XRF testing, transparent weighing, and
          immediate payout. No storefront pressure, no mail-in uncertainty.
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href={`sms:${SITE.smsE164}`}>Text Photos for an Estimate</a>
          <a class="btn btn-ghost" href="/contact">Book an Appointment</a>
          <a class="btn btn-ghost" href={`tel:${SITE.phoneE164}`}>Call</a>
        </div>

        <div class="hero-badges">
          <span class="badge">XRF + scale in front of you</span>
          <span class="badge">Immediate payout</span>
          <span class="badge">Discreet mobile appointments</span>
          <span class="badge">Estate & high-value lots</span>
        </div>

        <div class="hr"></div>

        <p class="muted"><strong>Service area:</strong> {SITE.serviceArea}</p>
      </div>

      <div>
        <CoinSpin label="Aurelius" />
        <div class="card" style="margin-top:16px">
          <h3>What makes us different</h3>
          <ul class="muted">
            {SITE.valueProps.map((v) => <li>{v}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="section">
      <h2>How it works</h2>
      <div class="grid grid-3" style="margin-top:14px">
        <div class="card">
          <h3>1) Send photos or book</h3>
          <p class="muted">Text photos for a quick estimate or schedule an appointment at your home/office.</p>
        </div>
        <div class="card">
          <h3>2) Test & weigh</h3>
          <p class="muted">We XRF test and weigh everything in front of you. Transparent, no guesswork.</p>
        </div>
        <div class="card">
          <h3>3) Get paid</h3>
          <p class="muted">If you accept, we pay immediately (Zelle/ACH/wire/check). Receipt + ID logged.</p>
        </div>
      </div>
    </section>

    <CTA />

    <section class="section">
      <h2>For estates & professionals</h2>
      <div class="card" style="margin-top:14px">
        <p class="muted">
          We’re built for estates, downsizing, divorce settlements, and high-value collections. Appraiser-forward positioning,
          documentation, and a clean process that protects clients from lowball buyers.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/appraisals">Appraisals</a>
          <a class="btn btn-ghost" href="/contact">Referral / Professional Inquiry</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
