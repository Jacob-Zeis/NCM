---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../site.config";
---

<BaseLayout
  title={`${SITE.name} — Sell Gold in North County San Diego`}
  description="Appointment-only precious metals buying in North County San Diego for gold jewelry, coins, bullion, silver, platinum, and estate lots."
  canonical="/"
>
  <div class="container">
    <main class="landing-body section-first">
      <section class="landing-hero" aria-label="North County Gold">
        <div class="landing-copy">
          <p class="eyebrow">North County Gold</p>
          <h1>Precious metals, reviewed in person.</h1>
          <p>
            Appointment-only buying in North County San Diego for gold, silver, platinum, coins, bullion, and estate lots.
          </p>
          <div class="landing-actions">
            <a class="btn btn-primary" href={`sms:${SITE.smsE164}`}>Text Photos</a>
            <a class="btn btn-ghost" href="/contact">Book Appointment</a>
          </div>
        </div>

        <aside class="landing-glance" aria-label="At a glance">
          <p class="eyebrow">At a glance</p>
          <ul>
            <li>Appointment-only</li>
            <li>North County San Diego</li>
            <li>XRF tested in person</li>
            <li>Immediate payout</li>
          </ul>
        </aside>
      </section>

      <section class="landing-process" aria-label="Process">
        <article>
          <h2>Text photos</h2>
          <p>Send clear images and visible markings.</p>
        </article>
        <article>
          <h2>Meet locally</h2>
          <p>Bring items to a private appointment.</p>
        </article>
        <article>
          <h2>Get paid</h2>
          <p>Accepted offers are paid immediately.</p>
        </article>
      </section>

      <section class="landing-reference" aria-label="Items and pricing">
        <div>
          <p class="eyebrow">What we buy</p>
          <ul class="landing-list">
            <li>Gold jewelry</li>
            <li>Coins &amp; bullion</li>
            <li>Silver</li>
            <li>Platinum</li>
            <li>Estate lots</li>
          </ul>
        </div>

        <div>
          <p class="eyebrow">Pricing factors</p>
          <ul class="landing-list">
            <li>Purity</li>
            <li>Weight</li>
            <li>Item type</li>
          </ul>
        </div>
      </section>

      <section class="landing-final" aria-label="Request a quote">
        <div>
          <p class="eyebrow">Quote request</p>
          <h2>Text photos first.</h2>
        </div>
        <div class="landing-actions">
          <a class="btn btn-primary" href={`sms:${SITE.smsE164}`}>Text Photos</a>
          <a class="btn btn-ghost" href="/contact">Contact</a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
