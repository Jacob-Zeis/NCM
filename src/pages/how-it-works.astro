---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import CardGrid from "../components/CardGrid.astro";
import PageIntro from "../components/PageIntro.astro";
import { PROCESS, SITE } from "../site.config";
---

<BaseLayout title={`How It Works — ${SITE.name}`} canonical="/how-it-works">
  <div class="container">
    <section class="section">
      <PageIntro title="How it works" lead="Photos first. Appointment second. Final offer after the item is reviewed in person." />
      <CardGrid items={PROCESS} />
    </section>

    <CTA />
  </div>
</BaseLayout>
